class BaseFinder {
    void find(int arr[], int n) {
        System.out.println("Base finder");
    }
}

class MissingFinder extends BaseFinder {

    @Override
    void find(int arr[], int n) {
        int total = n*(n+1)/2, sum=0;
        for(int i:arr) sum+=i;
        System.out.println("Missing = "+(total-sum));
    }

    void find(int arr[]) {   // overloading
        System.out.println("Array length = "+arr.length);
    }

    public static void main(String[] args) {
        MissingFinder m = new MissingFinder();
        int arr[]={1,2,4,5};
        m.find(arr,5);
        m.find(arr);
    }
}
